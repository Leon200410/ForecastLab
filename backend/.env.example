# ForecastLab backend configuration — copy to `.env` and fill in the keys you use.
# Precedence: repo-root .env (lowest) < backend/.env < real environment variables.
# Real providers only: without a valid LLM + search key the app fails loudly
# (it never fakes results). Polymarket market data is public (no key needed).

# ---- LLM provider (pick one) -----------------------------------------------
LLM_PROVIDER=deepseek                 # deepseek | anthropic

# DeepSeek (default; OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=0                   # 1 = extended reasoning (burns tokens); 0 = direct JSON

# Anthropic (only if LLM_PROVIDER=anthropic; also `pip install anthropic`)
ANTHROPIC_API_KEY=
FORECASTER_MODEL=claude-sonnet-4-6    # ensemble model when using Anthropic
CHEAP_MODEL=claude-haiku-4-5-20251001 # query-gen / assess / JSON-repair model

# ---- Web search (required for evidence) ------------------------------------
SEARCH_PROVIDER=tavily                # tavily | serper
SEARCH_API_KEY=

# ---- RAG embeddings (knowledge base) ---------------------------------------
EMBEDDING_PROVIDER=fastembed          # fastembed (ONNX, no torch) | sentence-transformers | local
FASTEMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# VOYAGE_API_KEY=                     # reserved; not yet implemented
KB_MIN_SCORE=0.2                      # cosine floor for injecting a past lesson

# ---- Forecasting / cost knobs ----------------------------------------------
ENSEMBLE_N=3                          # agent runs per forecast (temperature-laddered)
AGENT_RECURSION_LIMIT=30              # max LangGraph steps/run (too low -> GraphRecursionError -> no JSON)
LLM_MAX_RETRIES=3                     # retries w/ exp backoff on 429/5xx/timeout
MAX_SPEND_USD=5                       # soft cap on LLM spend PER DAY (raises BudgetExceeded)
CACHE_TTL_HOURS=0                     # disk-cache entry TTL (0 = never expire)

# ---- Portfolio (virtual paper trading) -------------------------------------
STARTING_BALANCE_USD=10000
DEFAULT_STAKE_USD=100

# ---- Ops -------------------------------------------------------------------
POLL_INTERVAL_MIN=60                  # background mark-to-market + settlement tick; 0 disables
AUTO_INGEST=1                         # pull open markets on startup if the store is empty
CORS_ORIGINS=http://localhost:5173,http://localhost:8080  # allowed browser origins (comma-sep)

# ---- Auth (internal team; OFF by default) ----------------------------------
# Optional per-user tokens "tok1:alice,tok2:bob". Empty = no gate (identity falls
# back to the X-User header from a reverse proxy, else "local"). Used for audit
# attribution + future per-user quotas. No JWT/RBAC.
API_TOKENS=
