# ---- LLM(必填一个真实 provider 的 key)---------------------------------
LLM_PROVIDER=deepseek                      # deepseek | anthropic
DEEPSEEK_API_KEY=                          # LLM_PROVIDER=deepseek 时必填
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash           # deepseek-v4-flash | deepseek-v4-pro
DEEPSEEK_THINKING=0                        # 0=非思考(结构化 JSON 稳定,推荐) | 1=思考链
ANTHROPIC_API_KEY=                         # LLM_PROVIDER=anthropic 时必填
FORECASTER_MODEL=claude-sonnet-4-6         # 仅 anthropic 时用
CHEAP_MODEL=claude-haiku-4-5-20251001      # 仅 anthropic 时用

# ---- 检索(必填)/ 嵌入 ------------------------------------------------
SEARCH_PROVIDER=tavily                     # tavily | serper
SEARCH_API_KEY=                            # 必填(Tavily 每月 1000 免费额度)
EMBEDDING_PROVIDER=local                   # local(内置,免费) | sentence-transformers | voyage
VOYAGE_API_KEY=                            # 仅 EMBEDDING_PROVIDER=voyage 时

# ---- 运行参数 -----------------------------------------------------------
POLL_INTERVAL_MIN=60                       # 后台轮询(盯市 + 揭晓)间隔(分钟)
DEFAULT_STAKE_USD=100                      # 手动押注表单预填注码
STARTING_BALANCE_USD=10000                 # 虚拟账户初始本金(唯一的"虚拟"部分)
MAX_SPEND_USD=5                            # LLM 花费软上限(美元),超限即停
ENSEMBLE_N=3                               # 同一盘子集成预测次数
AUTO_INGEST=1                              # 启动时自动拉取真实开放盘子

# ---- 前端 ---------------------------------------------------------------
# 留空 = 走相对路径 /api(dev 用 vite 代理,docker 用 nginx 代理)
VITE_API_BASE_URL=
